{
    "ci": {
        "collect": {
            "url": [
                "https://enderfare.github.io/website/"
            ]
        },
        "assert": {
            "assertions": {
                "categories:performance": [
                    "warn",
                    {
                        "minScore": 0.8
                    }
                ],
                "categories:accessibility": [
                    "warn",
                    {
                        "minScore": 0.9
                    }
                ],
                "categories:best-practices": [
                    "warn",
                    {
                        "minScore": 0.8
                    }
                ],
                "categories:seo": [
                    "warn",
                    {
                        "minScore": 0.8
                    }
                ]
            }
        },
        "upload": {
            "target": "filesystem",
            "outputDir": "./lhci_reports"
        }
    }
}